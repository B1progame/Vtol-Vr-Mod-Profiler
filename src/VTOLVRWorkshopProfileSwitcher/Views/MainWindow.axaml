<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels"
        xmlns:conv="clr-namespace:VTOLVRWorkshopProfileSwitcher.Converters"
        xmlns:pagesVm="clr-namespace:VTOLVRWorkshopProfileSwitcher.ViewModels.Pages"
        xmlns:pages="clr-namespace:VTOLVRWorkshopProfileSwitcher.Views.Pages"
        mc:Ignorable="d"
        x:Class="VTOLVRWorkshopProfileSwitcher.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Title="VTOL VR Switcher"
        Width="1560"
        Height="940"
        MinWidth="1200"
        MinHeight="760"
        Background="{DynamicResource WindowBackgroundBrush}"
        Opacity="0">
  <Window.Transitions>
    <Transitions>
      <DoubleTransition Property="Opacity" Duration="0:0:0.24" Easing="CircularEaseOut" />
    </Transitions>
  </Window.Transitions>

  <Window.DataTemplates>
    <DataTemplate DataType="pagesVm:DashboardPageViewModel">
      <pages:DashboardPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:ProfilesPageViewModel">
      <pages:ProfilesPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:ProfileDetailsPageViewModel">
      <pages:ProfileDetailsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:ModsPageViewModel">
      <pages:ModsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:BackupsPageViewModel">
      <pages:BackupsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:LogsPageViewModel">
      <pages:LogsPageView />
    </DataTemplate>
    <DataTemplate DataType="pagesVm:SettingsPageViewModel">
      <pages:SettingsPageView />
    </DataTemplate>
  </Window.DataTemplates>

  <Window.Resources>
    <conv:BoolToGridLengthConverter x:Key="DetailsWidthConverter" TruePixels="420" FalsePixels="0" />
  </Window.Resources>

  <Border Classes="shell-frame" Margin="14">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="272" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="{Binding IsDetailsOpen, Converter={StaticResource DetailsWidthConverter}}" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Classes="sidebar-panel" Padding="12" Margin="0,0,12,0">
      <Grid RowDefinitions="Auto,*,Auto">
        <TextBlock Text="VTOL VR Switcher"
                   FontSize="23"
                   FontWeight="Bold"
                   Height="84"
                   Margin="4,8,4,12"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   LineHeight="28"
                   MaxWidth="236" />

        <StackPanel Grid.Row="1" Spacing="0">
          <Button Content="Dashboard" Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsDashboardSelected}" Command="{Binding NavigateDashboardCommand}" />
          <Button Content="Profiles" Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsProfilesSelected}" Command="{Binding NavigateProfilesCommand}" />
          <Button Content="Mods" Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsModsSelected}" Command="{Binding NavigateModsCommand}" />
          <Button Content="Backups" Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsBackupsSelected}" Command="{Binding NavigateBackupsCommand}" />
          <Button Content="Logs" Classes="sidebar-item" Classes.sidebar-item-active="{Binding IsLogsSelected}" Command="{Binding NavigateLogsCommand}" />
          <Button Classes="sidebar-item"
                  Classes.sidebar-item-active="{Binding IsSettingsSelected}"
                  Classes.update-alert="{Binding HasUpdateAvailable}"
                  Command="{Binding NavigateSettingsCommand}">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
              <TextBlock Text="Settings" VerticalAlignment="Center" />
              <Border Grid.Column="1"
                      Classes="settings-warning-badge"
                      IsVisible="{Binding HasUpdateAvailable}"
                      VerticalAlignment="Center">
                <TextBlock Text="!" />
              </Border>
            </Grid>
          </Button>
        </StackPanel>

        <Border Grid.Row="2" Classes="sidebar-play-bar" Margin="0,16,0,0">
          <Grid ColumnDefinitions="*,52">
            <Button Content="{Binding SidebarPlayText}"
                    Classes="split-button-main"
                    IsEnabled="{Binding CanLaunchGame}"
                    PointerEntered="OnLaunchButtonPointerEntered"
                    PointerExited="OnLaunchButtonPointerExited"
                    Command="{Binding PlayModdedCommand}" />
            <Border Grid.Column="1" BorderBrush="{DynamicResource BorderDark}" BorderThickness="1,0,0,0">
              <Button Content="▼" Classes="split-button-arrow" IsEnabled="{Binding CanLaunchGame}">
                <Button.Flyout>
                  <Flyout Placement="TopEdgeAlignedRight">
                    <Border Classes="launch-flyout-panel">
                      <StackPanel Spacing="8" Width="176" DataContext="{Binding DataContext, ElementName=RootWindow}">
                        <Button Content="Play (Modded)" Classes="launch-flyout-button" Command="{Binding PlayModdedCommand}" />
                        <Button Content="Play (Vanilla)" Classes="launch-flyout-button" Command="{Binding PlayVanillaCommand}" />
                      </StackPanel>
                    </Border>
                  </Flyout>
                </Button.Flyout>
              </Button>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border Grid.Column="1" Classes="main-content-panel" Padding="14">
      <ContentControl Content="{Binding CurrentPageViewModel}" />
    </Border>

    <Border Grid.Column="2"
            Classes="details-panel card-panel"
            Padding="12"
            IsVisible="{Binding IsDetailsOpen}">
      <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Details" Classes="section-title" />
          <Button Grid.Column="1" Content="Hide" Classes="secondary-button" Command="{Binding ToggleDetailsCommand}" />
        </Grid>

        <StackPanel Grid.Row="1" Spacing="2">
          <TextBlock Text="{Binding SelectedModTitle}" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" />
          <TextBlock Text="{Binding SelectedModAuthor, StringFormat=Author: {0}}" Classes="text-muted" />
          <TextBlock Text="{Binding SelectedModLastUpdated, StringFormat=Last Updated: {0}}" Classes="text-muted" />
        </StackPanel>

        <Border Grid.Row="2" Height="180" CornerRadius="8" Background="#223046" ClipToBounds="True">
          <Image Source="{Binding SelectedMod.ThumbnailImage}" Stretch="UniformToFill" />
        </Border>

        <Border Grid.Row="3" Classes="card-panel" Padding="10">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
            <TextBlock Text="Workshop ID:" />
            <TextBlock Grid.Column="1" Text="{Binding SelectedModWorkshopId}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1" Text="Local Version:" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedModLocalVersion}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="2" Text="Remote Version:" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedModRemoteVersion}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="3" Text="Size:" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedModSize}" FontWeight="SemiBold" />
            <TextBlock Grid.Row="4" Text="Status:" />
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedModStatus}" FontWeight="SemiBold" />
            <Border Grid.Row="5" Grid.ColumnSpan="2" Classes="status-badge" IsVisible="{Binding SelectedModHasUpdate}">
              <TextBlock Text="UPDATE AVAILABLE" />
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="4" Classes="card-panel" Padding="10" IsVisible="{Binding HasSelectedProfileModEntry}">
          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
            <TextBlock Text="Active In Profile:" VerticalAlignment="Center" />
            <ToggleSwitch Grid.Column="1"
                          Margin="8,0,0,0"
                          HorizontalAlignment="Left"
                          IsChecked="{Binding SelectedProfileModActiveInProfile, Mode=TwoWay}" />
            <Button Grid.Column="2"
                    Margin="8,0,0,0"
                    Content="Remove From Profile"
                    Classes="warning-button"
                    Command="{Binding RemoveSelectedProfileModFromDetailsCommand}" />
            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="3"
                       Margin="0,8,0,0"
                       Classes="text-muted"
                       Text="Deactivating keeps the mod in this profile but excludes it when applying the profile." />
          </Grid>
        </Border>

        <Grid Grid.Row="5" ColumnDefinitions="*,*">
          <Button Content="Update" Classes="warning-button" Command="{Binding UpdateSelectedModCommand}" />
          <Button Grid.Column="1" Margin="8,0,0,0" Content="Open Workshop" Classes="secondary-button" Command="{Binding OpenSelectedModWorkshopCommand}" />
        </Grid>

        <Grid Grid.Row="6" ColumnDefinitions="*,*" Margin="0,8,0,0">
          <Button Content="Add To Profile"
                  Classes="primary-button"
                  Command="{Binding AddSelectedModToCurrentProfileCommand}"
                  CommandParameter="{Binding SelectedMod}" />
          <Button Grid.Column="1"
                  Margin="8,0,0,0"
                  Content="Delete Mod"
                  Classes="danger-button"
                  Command="{Binding DeleteModCommand}"
                  CommandParameter="{Binding SelectedMod}" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
  </Border>
</Window>

