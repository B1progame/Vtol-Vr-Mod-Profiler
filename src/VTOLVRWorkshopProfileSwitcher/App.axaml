<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VTOLVRWorkshopProfileSwitcher.App"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <SolidColorBrush x:Key="AppBackground" Color="#121417" />
    <SolidColorBrush x:Key="SidebarBackground" Color="#171A1F" />
    <SolidColorBrush x:Key="SurfaceBackground" Color="#1E2228" />
    <SolidColorBrush x:Key="CardBackground" Color="#242932" />
    <SolidColorBrush x:Key="BorderDark" Color="#2A2F36" />
    <SolidColorBrush x:Key="AccentRedSubtle" Color="#5A1E1E" Opacity="0.55" />
    <SolidColorBrush x:Key="TextPrimary" Color="#E6EAF0" />
    <SolidColorBrush x:Key="TextSecondary" Color="#9AA3AD" />
    <SolidColorBrush x:Key="SuccessGreen" Color="#3C7A4A" />

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#121417" />
    <SolidColorBrush x:Key="BorderBrushAccentRed" Color="#5A1E1E" Opacity="0.55" />
    <SolidColorBrush x:Key="BorderBrushDefault" Color="#2A2F36" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="#121417" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E2228" />
    <SolidColorBrush x:Key="CardBrush" Color="#242932" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2A2F36" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="#343941" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#3C7A4A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#8C6A35" />
    <SolidColorBrush x:Key="DangerBrush" Color="#7E3A3A" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E6EAF0" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9AA3AD" />

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#121417" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#171A1F" />
    <SolidColorBrush x:Key="MainPanelBackgroundBrush" Color="#1E2228" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#242932" />
    <SolidColorBrush x:Key="BorderSoftBrush" Color="#2A2F36" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#9AA3AD" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI, Arial" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="Background" Value="{DynamicResource AppBackground}" />
    </Style>

    <Style Selector="TextBox, ComboBox, ListBox">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style Selector="Button">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#2A2E35" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#323740" />
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="#252A31" />
    </Style>

    <Style Selector="Border.card-panel">
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushAccentRed}" />
      <Setter Property="BoxShadow" Value="0 6 18 0 #28000000" />
    </Style>

    <Style Selector="Border.toolbar-panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushAccentRed}" />
    </Style>

    <Style Selector="Border.sidebar-panel">
      <Setter Property="Background" Value="{DynamicResource SidebarBackground}" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushAccentRed}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="0 10 26 0 #2D000000" />
    </Style>

    <Style Selector="Border.main-content-panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushAccentRed}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="0 10 26 0 #26000000" />
    </Style>

    <Style Selector="Border.details-panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushAccentRed}" />
    </Style>

    <Style Selector="Border.shell-frame">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushAccentRed}" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Button.sidebar-item">
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="MinHeight" Value="68" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="FontSize" Value="17" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,14" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderDark}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.sidebar-item:pointerover">
      <Setter Property="Background" Value="#252A31" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style Selector="Button.sidebar-item.sidebar-item-active">
      <Setter Property="Background" Value="#2F353E" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentRedSubtle}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style Selector="Button.primary-button">
      <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderDark}" />
    </Style>

    <Style Selector="Button.success-button">
      <Setter Property="Background" Value="{DynamicResource SuccessGreen}" />
      <Setter Property="BorderBrush" Value="#355F40" />
      <Setter Property="Foreground" Value="#F6FFF8" />
    </Style>

    <Style Selector="Button.warning-button">
      <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
      <Setter Property="BorderBrush" Value="#FFD184" />
      <Setter Property="Foreground" Value="#162130" />
    </Style>

    <Style Selector="Button.danger-button">
      <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
      <Setter Property="BorderBrush" Value="#E18A91" />
    </Style>

    <Style Selector="Button.secondary-button">
      <Setter Property="Background" Value="#2F353E" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderDark}" />
    </Style>

    <Style Selector="Button.primary-button:pointerover">
      <Setter Property="Background" Value="#3A4048" />
    </Style>
    <Style Selector="Button.success-button:pointerover">
      <Setter Property="Background" Value="#478B57" />
    </Style>
    <Style Selector="Button.warning-button:pointerover">
      <Setter Property="Background" Value="#E8AF48" />
    </Style>
    <Style Selector="Button.secondary-button:pointerover">
      <Setter Property="Background" Value="#383F49" />
    </Style>

    <Style Selector="Border.sidebar-play-bar">
      <Setter Property="Height" Value="52" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Background" Value="#1C232D" />
      <Setter Property="BorderBrush" Value="#313A48" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Button.split-button-main">
      <Setter Property="MinHeight" Value="52" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Background" Value="#1C232D" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Padding" Value="14,4" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.split-button-arrow">
      <Setter Property="MinHeight" Value="52" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Background" Value="#1C232D" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.split-button-main:pointerover">
      <Setter Property="Background" Value="#25303E" />
    </Style>

    <Style Selector="Button.split-button-arrow:pointerover">
      <Setter Property="Background" Value="#25303E" />
    </Style>

    <Style Selector="Button.split-button-main:pressed">
      <Setter Property="Background" Value="#17202A" />
    </Style>

    <Style Selector="Button.split-button-arrow:pressed">
      <Setter Property="Background" Value="#17202A" />
    </Style>

    <Style Selector="Border.launch-flyout-panel">
      <Setter Property="Padding" Value="10" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="#1A2029" />
      <Setter Property="BorderBrush" Value="#2F3948" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.launch-flyout-button">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Background" Value="#253140" />
      <Setter Property="BorderBrush" Value="#34445A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#EAF1FF" />
    </Style>

    <Style Selector="Button.launch-flyout-button:pointerover">
      <Setter Property="Background" Value="#2D3A4D" />
      <Setter Property="BorderBrush" Value="#446081" />
    </Style>

    <Style Selector="Button.launch-flyout-button:pressed">
      <Setter Property="Background" Value="#202A36" />
    </Style>

    <Style Selector="Button.big-play-button">
      <Setter Property="MinHeight" Value="54" />
      <Setter Property="FontSize" Value="34" />
      <Setter Property="Padding" Value="12,12" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="Border.kpi-card">
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderDark}" />
      <Setter Property="BoxShadow" Value="0 4 14 0 #28000000" />
    </Style>

    <Style Selector="Border.kpi-red">
      <Setter Property="Background" Value="#A64556" />
    </Style>
    <Style Selector="Border.kpi-green">
      <Setter Property="Background" Value="#2F8B58" />
    </Style>
    <Style Selector="Border.kpi-orange">
      <Setter Property="Background" Value="#BE7331" />
    </Style>
    <Style Selector="Border.kpi-blue">
      <Setter Property="Background" Value="#3A4048" />
    </Style>

    <Style Selector="Border.mod-card">
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BoxShadow" Value="0 4 12 0 #22000000" />
      <Setter Property="Margin" Value="0,0,12,12" />
      <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="25" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.text-muted">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="TextBlock.kpi-value">
      <Setter Property="FontSize" Value="40" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#F3F7FF" />
    </Style>

    <Style Selector="Border.status-badge">
      <Setter Property="Background" Value="#E5B52C" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
  </Application.Styles>
</Application>
